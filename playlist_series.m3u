#EXTINF:-1 tvg-logo="https://image.tmdb.org/t/p/w600_and_h900_bestv2/nhxFwgLom7MtvKvCEQYJHpZ3dFk.jpg" group-title="SERIES · |ES| ESPANA SERIES" tvg-type="series" tvg-season="1" tvg-episode="1" series-name="ES - Asuntos internos (2025)" description="Año 1979, Clara Montesinos, miembro de la primera promoción de mujeres policía, llega a una comisaría en la que la irrupción de la heroína condiciona la vida de nuestros protagonistas y de todo el barrio. Allí, la nueva inspectora va a aprender que ser agente es mucho más duro de lo que pensó, y más en ese destino." year="2025-02-12" director="Pedro García Ríos, Rodrigo Martín" actors="Laia Manzanares, Silvia Abascal, Marta Poveda, Nacho Fresneda, Luis Callejo, Carla Campra, Miki Esparbé, Jorge de Juan",ES - Asuntos internos (2025) S01E01
