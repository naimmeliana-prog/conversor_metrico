#EXTINF:-1 tvg-logo="https://image.tmdb.org/t/p/w600_and_h900_bestv2/gLatb5eouLTAWrJGKA1QqMJMoFx.jpg" group-title="|FR| FILMS 2026" tvg-type="movie" description="Dans le quartier russe de West Hollywood, Margarita vit le rêve américain: participer à une émission de téléréalité. Va-t-elle tuer, servir ou survivre ?" year="2026-02-27" director="Nastasya Popov" actors="Anna Baryshnikov, Galina Jovovich, Mark Ivanir, Nerses Stamos, Camila Mendes, Owen Thiele, Julia Fox, Saweetie, Benito Skinner, Jake Choi",FR - Idiotka (2026)
