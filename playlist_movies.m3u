#EXTINF:-1 tvg-logo="https://image.tmdb.org/t/p/w600_and_h900_bestv2/3GVN9OdiRASyTTNwHfNxYYiB9Yn.jpg" group-title="|PL| AKCJA/SENSACJA/KRYMINAŁ" tvg-type="movie" description="Dwoje młodych kochanków podróżuje po kraju dokonując napadów. Swoje wyczyny publikują w mediach społecznościowych, zyskując w ten sposób sławę i fanów." year="2020-06-12" director="Joshua Caldwell" actors="Bella Thorne, Jake Manley, Amber Riley, Michael Sirow, Marisa Coughlan, Aaliyah Muhammad, Madi Bready, Rose Lane Sanfilippo, Damon Carney, Joey Oglesby",PL - ZABÓJCZY KOCHANKOWIE (2020)
