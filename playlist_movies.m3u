#EXTINF:-1 tvg-logo="https://image.tmdb.org/t/p/w600_and_h900_bestv2/p0qqnfmhmJYYz73jK7UOwP3ZUgn.jpg" group-title="|FR| HORREUR/EPOUVANTE" tvg-type="movie" description="Everything goes to hell for newly-pregnant Belinda after her mother-in-law moves in. As the diabolical guest tries to get her claws on the child, Belinda must draw the line somewhere." year="2024-09-05" director="Max Eggers, Sam Eggers, Mattheau O'Brien, Jesse Rosen, Tony Manzo" actors="Brandy Norwood, Andrew Burnap, Kathryn Hunter, Neal Huff, David Manis",FR - The Front Room (2024)
