#EXTINF:-1 tvg-logo="https://image.tmdb.org/t/p/w600_and_h900_bestv2/eKSI1r9fpkvvoVWAU8V4DTs4ucb.jpg" group-title="|DE| ANIME FILME" tvg-type="movie" description="Eine Gruppe junger Leute wird vom Inhaber einer Internetbar gesponsert, um ein E-Sportteam für die Teilnahme an den nationalen Wettbewerben zu bilden." year="2019-08-16" director="Shi Juansheng" actors="Zhang Jie, Xinzhu Tong, Liu Kang, Guo Haoran, Wen jingyuan, Zhang Zhe",DE - The King’s Avatar: For The Glory (2019)
