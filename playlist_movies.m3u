#EXTINF:-1 tvg-logo="https://image.tmdb.org/t/p/w600_and_h900_bestv2/s5CnGT58WWE5mz5cQ4zBfv1HT0J.jpg" group-title="|PL| PRZYGODOWE/HISTORYCZNE/KOSTIUMOWE" tvg-type="movie" description="W królestwie zapanował chaos i nadeszła klęska głodu. Mimo zebranej armii, nie było pewne czy kraj przetrwa..." year="2020-09-09" director="Yuxi Li" actors="Liu Chuxuan, Li Mao, Pema Jyad, Zhang Hengrui, Liu Yong, Liao Huijia, Luo Datao",PL - LEGENDA HUA MULAN (2020)
