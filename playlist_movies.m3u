#EXTINF:-1 tvg-logo="https://image.tmdb.org/t/p/w600_and_h900_bestv2/oyQXRZD0CHC4sf3lMph3X3cJzSw.jpg" group-title="|ES| LATINO" tvg-type="movie" description="La historia de Trudy Ederle, quien en 1926 fue la primera mujer en cruzar a nado el Canal de la Mancha." year="2024-05-31" director="Joachim Rønning" actors="Daisy Ridley, Tilda Cobham-Hervey, Stephen Graham, Kim Bodnia, Jeanette Hain, Glenn Fleshler, Sian Clifford, Christopher Eccleston, Ethan Rouse, Olive Elise Abercrombie",LAT - La joven y el mar (2024)
