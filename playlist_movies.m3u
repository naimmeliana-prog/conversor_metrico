#EXTINF:-1 tvg-logo="https://m.media-amazon.com/images/M/MV5BZTNjOGYwNjEtNjU2YS00MDVjLWI3ZTUtN2JjOWVkYThhYmRjXkEyXkFqcGdeQXVyOTMzOTMzMTg@._V1_.jpg" group-title="|PL| PRZYGODOWE/HISTORYCZNE/KOSTIUMOWE" tvg-type="movie" description="Akcja rozgrywa się w zamarzniętym świecie postapokaliptycznego roku 2144. Młoda wojowniczka wychowana przez niedźwiedzia polarnego musi walczyć o przetrwanie po tym, jak zostaje schwytana i ucieknie przed brutalnym rywalizującym plemieniem." year="2022-07-14" director="Kirsten Carthew" actors="Viva Lee, Khamisa Wilsher, Muriel Dutil, Kara Wooten, Dinah Gaston, Charlene Francique, Aimée Robinson, LeaAnne McNally, Charlene Abraham, Veronique Boileau",PL - POLARIS (2022)
