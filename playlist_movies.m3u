#EXTINF:-1 tvg-logo="https://image.tmdb.org/t/p/w600_and_h900_bestv2/5EpIjplAtUiFyjR6C2gYN6xPiCP.jpg" group-title="|FR| NETFLIX" tvg-type="movie" description="Lors d'un road trip entrepris à travers le Punjab pour que l'un d'entre eux se remette d'une méchante rupture, quatre amis se retrouvent rapidement au cœur d'un fiasco inouï." year="2024-07-10" director="Simarpreet Singh" actors="Varun Sharma, Sunny Singh, Jassie Gill, Manjot Singh, Ishita Raj Sharma, Patralekhaa, Gopal Datt, Rajesh Sharma, Anjum Batra",FR - Wild Wild Punjab (2024)
