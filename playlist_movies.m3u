#EXTINF:-1 tvg-logo="https://image.tmdb.org/t/p/w600_and_h900_bestv2/89X0k6DpFdMUy10auKziPKYUkd9.jpg" group-title="|PL| HORROR/THRILLER" tvg-type="movie" description="Trzynastoletnia dziewczyna w samoobronie zabija chłopaka swojej uzależnionej matki. Wkrótce ponownie musi walczyć o życie." year="2024-10-09" director="Jayden Creighton" actors="Riley Channells, Whitney Duff, Juliette Greenfield, Kate Logan, Claire Weller Price, Andy Sparnon, Sami Walker, William Tarrant, Kim Orams, Ben Connolly",PL - Dawne grzechy   (2024)
