#EXTINF:-1 tvg-logo="https://image.tmdb.org/t/p/w600_and_h900_bestv2/h6caee9nexiPgidsuR7ltSnaZYG.jpg" group-title="|FR| FILM 1980-1999" tvg-type="movie" description="Triad boss Lung, who has just escaped being killed in an assassination attempt hires the killers Curtis, James, Mike, Roy and Shin for his protection." year="1999-11-19" director="Johnnie To" actors="Anthony Wong, Francis Ng, Jackie Lui Chung-Yin, Roy Cheung, Lam Suet, Simon Yam, Wong Tin-Lam, Eddy Ko, Elaine Eca Da Silva, Keiji Sato",FR - The Mission (1999)
