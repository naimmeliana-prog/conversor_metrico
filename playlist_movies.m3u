http://mag.greatott.me:80/play/movie.php?mac=00:1A:79:74:B1:B9&stream=1729404.mkv&play_token=w9Zdh9oTi6&type=movie&dummy=/movie/&type=movie

#EXTINF:-1 tvg-logo="https://image.tmdb.org/t/p/w600_and_h900_bestv2/bwBkzMHDAAfnmbbRT3VOVQLKF3q.jpg" group-title="|FR| PRIME +" tvg-type="movie" description="Après l'enlèvement du Père Noël, le chef de la sécurité du pôle Nord doit faire équipe avec le chasseur de primes le plus célèbre du monde dans une mission pleine d'action à travers le monde pour sauver Noël." year="2024-10-31" director="Jake Kasdan" actors="Dwayne Johnson, Chris Evans, J.K. Simmons, Lucy Liu, Kiernan Shipka, Bonnie Hunt, Kristofer Hivju, Nick Kroll, Wesley Kimmel, Mary Elizabeth Ellis",FR - Red One (2024) HQ
