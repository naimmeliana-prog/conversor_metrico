http://mag.greatott.me:80/play/movie.php?mac=00:1A:79:74:B1:B9&stream=2110469.mkv&play_token=ZCvtcjyaMi&type=movie&dummy=/movie/&type=movie

#EXTINF:-1 tvg-logo="https://image.tmdb.org/t/p/w600_and_h900_bestv2/ylgaqq0NdSlnrBRtWMePYvDlTDa.jpg" group-title="|DE| DOKUMENTATION" tvg-type="movie" description="Fußballer, Geschäftsmann, Fan-Idol und wahrer Lokalheld: Lukas Podolski reflektiert in dieser eindrucksvollen Dokumentation über seine Karriere und seine Zukunft." year="2026-06-04" director="Nicolas Berse, Simone Schillinger, Kai Sehr" actors="Lukas Podolski, Joachim Löw, Oliver Kahn, Thomas Müller, Bastian Schweinsteiger",DE - Poldi (2026)
