#EXTINF:-1 tvg-logo="https://image.tmdb.org/t/p/w600_and_h900_bestv2/7TBO4qM8dDl3PkR6zRzKWOXBKW7.jpg" group-title="|PL|  FILMY 4K" tvg-type="movie" description="Wichrowe wzgórza w reżyserii _Emerald Fennell_ (o647069) to odważna i oryginalna wersja jednej z największych historii miłosnych wszech czasów. _Margot Robbie_ (o585791) i _Jacob Elordi_ (o1039451) wcielają się w Cathy i Heathcliffa, których zakazana, romantyczna namiętność z czasem staje się toksyczna. Film jest monumentalną opowieścią o pożądaniu, miłości i szaleństwie." year="2026-02-11" director="Emerald Fennell" actors="Margot Robbie, Jacob Elordi, Hong Chau, Alison Oliver, Shazad Latif, Martin Clunes, Ewan Mitchell, Amy Morgan, Jessica Knappett, Charlotte Mellington",PL 4K - “Wichrowe Wzgórza” (2026)  Dubbing
