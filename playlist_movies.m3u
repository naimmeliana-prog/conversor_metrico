#EXTINF:-1 tvg-logo="https://image.tmdb.org/t/p/w600_and_h900_bestv2/zwBjTDwXsrDhKY80zIX7F4oi1is.jpg" group-title="|ES| PELICULAS 2000/2010" tvg-type="movie" description="Ben Manalowitz, periodista y presentador de podcasts, viaja desde la ciudad de Nueva York hasta el oeste de Texas para investigar la muerte de una chica con la que estaba saliendo." year="2022-07-29" director="B. J. Novak" actors="B. J. Novak, Boyd Holbrook, J. Smith-Cameron, Issa Rae, Ashton Kutcher, Lio Tipton, Dove Cameron, Isabella Amara, Eli Bickel, John Mayer",ES - Venganza (Vengeance) - (2022)
