#EXTINF:-1 tvg-logo="https://image.tmdb.org/t/p/w600_and_h900_bestv2/g0caMsvQ53w8PpzcaE3fkDSwl8W.jpg" group-title="|ES| PELICULAS 2020/2023" tvg-type="movie" description="La noche antes de jubilarse, el teniente de policía Franco Amore es llamado para investigar la escena del crimen donde mataron a su mejor amigo y compañero de toda la vida, Dino." year="2023-03-09" director="Andrea Di Stefano" actors="Pierfrancesco Favino, Linda Caridi, Antonio Gerardi, Francesco Di Leva, Wang Fifi, Katia Mironova, Carlo Gallo, Camilla Semino Favro, Martin Francisco Montero Baez, Fabrizio Rocchi",ES - Última noche en Milán (2023)
