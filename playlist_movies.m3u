#EXTINF:-1 tvg-logo="https://image.tmdb.org/t/p/w600_and_h900_bestv2/gr3oOAUYR4ttdYPfd1Nr9bUMCf5.jpg" group-title="|FR| COMÉDIE/DRAME" tvg-type="movie" description="Pressured from all sides by the figure of her father, Chiara Mastroianni decides to bring him back to life through her own self. She goes by the name of Marcello, dresses like him and asks to now be considered an actor, not an actress. The people around her believe this to be a temporary joke, but Chiara is determined not to give up her new identity…" year="2024-05-21" director="Julie Gouet, Christophe Honoré" actors="Chiara Mastroianni, Catherine Deneuve, Fabrice Luchini, Nicole Garcia, Benjamin Biolay",Marcello Mio (2024)
