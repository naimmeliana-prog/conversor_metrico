#EXTINF:-1 tvg-logo="https://image.tmdb.org/t/p/w600_and_h900_bestv2/cfZfl3wxO8QxHKJsiWUHZg1D62B.jpg" group-title="|FR| FILM 1980-1999" tvg-type="movie" description="Ere préhistorique. Atouk et Lar, deux hommes des cavernes, font équipe pour former une tribu. Lorsqu'Attouk tombe amoureux de la compagne de Tonda, les choses se compliquent très vite..." year="1981-04-17" director="Turman-Foster Company" actors="N/A",FR - L'homme des cavernes  (1981)
