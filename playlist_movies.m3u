#EXTINF:-1 tvg-logo="https://m.media-amazon.com/images/M/MV5BODQ4MTk1NzMtODBmYi00MWI1LThiNWUtYTA0ZGE5ZDZkOTkxXkEyXkFqcGdeQXVyMTEzMTI1Mjk3._V1_.jpg" group-title="|PL| THRILLER" tvg-type="movie" description="Pogrążona w żałobie po stracie przyjaciółki, której nie udało jej się uratować, była ochroniarka postanawia spełnić ostatnie życzenie zmarłej — zemścić się." year="2023-10-05" director="Lee Chung-hyun" actors="Jun Jong-seo, Kim Ji-hun, Park Yu-rim, Shin Se-hwi, Park Hyeong-su, Park Geun-jeong, Yang Jun-seok, Lee Jae-joon, Kim Yeong-ok, Joo Hyun",PL - BALERINA (2023)
