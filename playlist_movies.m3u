#EXTINF:-1 tvg-logo="https://image.tmdb.org/t/p/w600_and_h900_bestv2/qvZ1YlYq6jBmZYps6EAY4k9EZOj.jpg" group-title="|PL| THRILLER" tvg-type="movie" description="W filmie 'Dobry Chłopak Z Bronią', przeniesiecie się do małego, amerykańskiego miasteczka, gdzie plan sprzedaży domu po dziadku stanie się początkiem dramatycznej podróży przez mroczne zakamarki ludzkiej psychiki." year="2022-12-02" director="John Mossman" actors="Beck Nolan, Tiffany Bedwell, Jack Cain, Ian Barford, Dan Waller, David Pasquesi, Joe Swanberg",PL - DOBRY CHŁOPAK Z BRONIĄ (2022)
