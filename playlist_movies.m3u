#EXTINF:-1 tvg-logo="https://image.tmdb.org/t/p/w600_and_h900_bestv2/8vfyhKkTwvxbV5UuuIMBP0BLILv.jpg" group-title="|PL| ROMANS/MIŁOŚĆ" tvg-type="movie" description="Matt (Jonah Platt) zdradza swoją narzeczoną, Abby (Halston Sage) z celebrytką ze swojej listy 'wyjątków od monogamii'. Załamana Abby postanawia zrobić to samo z kimś znanym z własnej listy." year="2023-08-21" director="Melissa B. Miller-Costanzo" actors="Halston Sage, Christian Navarro, Jonah Platt, Shelley Hennig, Clark Backo, Chrissie Fit, Gregg Sulkin, Will Peltz, Geoff Pierson, Brendan Meyer",PL - THE LIST (2023)
