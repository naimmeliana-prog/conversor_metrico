#EXTINF:-1 tvg-logo="https://image.tmdb.org/t/p/w600_and_h900_bestv2/zMdJdI74PdObENl4RfU3o5lC0VM.jpg" group-title="|PL| DRAMAT" tvg-type="movie" description="Młoda funkcjonariuszka rzuca wszystko, żeby udawać członkinię ETA, i ryzykuje życiem, aby poznać kryjówki terrorystów zlokalizowane na południu Francji." year="2025-10-03" director="Agustín Díaz Yanes, Richard Diment, Gorka Cornejo, Benito Bejimbé, Esther Rojas" actors="Susana Abaitua, Andrés Gertrúdix, Iraia Elias, Ariadna Gil, Raúl Arévalo",PL - Spowita w mrok (2025)
