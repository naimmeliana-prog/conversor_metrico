#EXTINF:-1 tvg-logo="https://image.tmdb.org/t/p/w600_and_h900_bestv2/rzQMvvS8StqQsNBzuzPk4eCjvjn.jpg" group-title="|PL| PRZYGODOWE/HISTORYCZNE/KOSTIUMOWE" tvg-type="movie" description="Ekipa budowlana, która kopie tunel, przypadkowo zakłóca spokój stworzenia mieszkającego pod ziemią, prowokując bestię do ataku." year="2022-02-25" director="Huang He" actors="Wei Wei, Wei Lu, Zhang Chunzhong, Yue Dongfeng, Li Ruoxi, Tang Xin, Zhang Shuangli, Li Gaoji",PL - POTWÓR Z GŁĘBIN (2022)
