#EXTINF:-1 tvg-logo="https://image.tmdb.org/t/p/w600_and_h900_bestv2/oYXaJmBwPhiVAMlRIiIKhKptvc0.jpg" group-title="|FR| COMÉDIE/DRAME" tvg-type="movie" description="Renn Wheeland returns home to Cleveland for his mother's funeral. Once there, he forges new relationships while healing old ones, before confronting his problems and trying to face his grief." year="2024-07-23" director="Robert Schwartzman" actors="Nick Jonas, Brittany Snow, Alexandra Shipp, David Arquette, Matt Walsh",The Good Half (2024)
http://mag.greatott.me:80/play/movie.php?mac=00:1A:79:74:B1:B9&stream=1632058.mkv&play_token=s59leHrAxf&type=movie&dummy=/movie/&type=movie

