#EXTINF:-1 tvg-logo="https://image.tmdb.org/t/p/w600_and_h900_bestv2/1ttiBVbzQl9eQ640JnNPHwfm7EZ.jpg" group-title="|FR| FILM 1980-1999" tvg-type="movie" description="A virtuous Hong Kong police officer must clear his name after he is framed for murder." year="1985-12-14" director="Jackie Chan" actors="Jackie Chan, Brigitte Lin, Maggie Cheung, Bill Tung, Chor Yuen, Charlie Cho, Mars, Lam Gwok-Hung, David Lau, Kam Hing-Yin",FR - Police Story  (1985)
http://mag.greatott.me:80/play/movie.php?mac=00:1A:79:74:B1:B9&stream=559368.mkv&play_token=BbMVTaL5R2&type=movie&dummy=/movie/&type=movie

