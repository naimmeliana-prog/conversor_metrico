#EXTINF:-1 tvg-logo="https://image.tmdb.org/t/p/w600_and_h900_bestv2/2qsCUy88FPiHxOSFXdkKlmJz7Hw.jpg" group-title="|PL| MUZYKA/TANIEC" tvg-type="movie" description="Utalentowana Melea Martin, ograniczana przez szkołe postanawia wykorzytać swój talent i zostać tancerką." year="2016-11-30" director="Bille Woodruff" actors="Cassie Ventura, Kenny Wormald, Dena Kaplan, Bobby Lockwood, Sibongile Mlambo, Sivuyile Ngesi, Clayton Evertson, Adrian Galley, Ambrose Uren, Juanique Randall",PL - HONEY 3 (2016)
