#EXTINF:-1 tvg-logo="https://image.tmdb.org/t/p/w600_and_h900_bestv2/lg8DZX6wQolIkkv3H8LhJWhexYa.jpg" group-title="|PL| DRAMAT" tvg-type="movie" description="Marian ucieka do opuszczonego domu swoich dziadków na wsi, gdy ona i jej mąż padają ofiarą ataku terrorystycznego w Wiedniu." year="2023-09-29" director="Elisabeth Scharang" actors="Brigitte Hobmeier, Gerti Drassl, Bogdan Dumitrache, Johannes Krisch, Larissa Fuchs, Ima Karoline Krisch, Dagmar Schwarz, Heinz Trixner, Heinrich Mayr, Miel Wanka",PL - Las (2023)
