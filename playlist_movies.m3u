#EXTINF:-1 tvg-logo="http://103.176.90.118/images/movies/pGpQEbQtOPFu8hCfxjQF6qKi0fV.jpg" group-title="|ES| NIÑOS/ANIMACION" tvg-type="movie" description="Tarzan y Jane Porter se enfrentan a un ejercito de mercenarios al mando del malvado CEO de Greystoke Energies, un hombre que se quedó al mando de la empresa de los padres de Tarzan después de que estos murieran en un accidente de avión." year="2013-10-17" director="Reinhard Klooss" actors="Kellan Lutz, Spencer Locke, Les Bubb, Joe Cappelletti, Brian Huskey, Mark Deklin, Jaime Ray Newman, Robert Capron, Jonathan Morgan Heit, Anton Zetterholm",ES - Tarzán (2013)
