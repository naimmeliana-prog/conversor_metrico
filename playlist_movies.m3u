#EXTINF:-1 tvg-logo="https://image.tmdb.org/t/p/w600_and_h900_bestv2/hPm6RPT9CrzzPzbIOHbB83w9dQ2.jpg" group-title="|PL|  FILMY 4K" tvg-type="movie" description="U progu zimnej wojny marszałkowie Frank i Tommy ścigają mordercę w Nevadzie, odkrywając spisek grożący fundamentom prawa." year="2025-01-10" director="Phil Blattenberger" actors="Jacob Keohane, Jackson Rathbone, Dermot Mulroney, Harvey Keitel, Keith Carradine, Graham Greene, Kelly Lynn Reiter, James Urbaniak, Forrie J. Smith, Richard Brake",PL 4K - Prawa ludzi (2025)
