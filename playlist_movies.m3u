#EXTINF:-1 tvg-logo="https://image.tmdb.org/t/p/w600_and_h900_bestv2/kdHEtyOoB8cyFDwqFMMGK1q0RlM.jpg" group-title="|PL| MUZYKA/TANIEC" tvg-type="movie" description="Dwójka piosenkarzy, którym nie udało się rozwinąć kariery, ryzykuje wszystko dla szansy zdobycia sławy i miłości" year="2025-08-21" director="Marla Ancheta" actors="Khalil Ramos, Sue Ramirez, Romnick Sarmenta, Gelli De Belen, Gladys Reyes, Vivoree Esclito, Lilet, Matt Lozano, Victor Medina, Dawit Tabonares",PL - Miłość na jedną piosenkę (2025)
