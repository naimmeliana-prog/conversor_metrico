#EXTINF:-1 tvg-logo="https://image.tmdb.org/t/p/w600_and_h900_bestv2/vq14BBYOYDMprLevoL9JCDaLAKL.jpg" group-title="|DE| DOKUMENTATION" tvg-type="movie" description="Filmmaker Uwe Boll accompanied the Bandidos MC for three years. For the first time, a documentary shows the history and inner workings of the brotherhood." year="2024-05-10" director="Uwe Boll" actors="Peter Maczollek, Leslav Hause",Bandidos and I (2024)
