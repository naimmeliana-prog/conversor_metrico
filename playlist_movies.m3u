#EXTINF:-1 tvg-logo="https://image.tmdb.org/t/p/w600_and_h900_bestv2/thQQ3BBBhGDtWm3UTtabhyDJd8U.jpg" group-title="|FR| FILMS 2026" tvg-type="movie" description="Une étrange porte apparaît dans le sous-sol d'un magasin de meubles." year="2026-05-27" director="Kane Parsons" actors="Chiwetel Ejiofor, Renate Reinsve, Mark Duplass, Finn Bennett, Lukita Maxwell, Avan Jogia, Robert Bobroczkyi, Ember Ambrose, Krista Kosonen, Philip Granger",FR - Backrooms (2026)
