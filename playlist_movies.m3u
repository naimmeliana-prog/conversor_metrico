#EXTINF:-1 tvg-logo="https://image.tmdb.org/t/p/w600_and_h900_bestv2/oR4dsvz6edpDXFGBUo6VTvi2IRu.jpg" group-title="|FR| FILMS 2026" tvg-type="movie" description="Tandis que sa famille fait le vide dans sa maison d'été, la petite Lide disparaît dans la forêt. Quand un incendie se déclare, sa mère se précipite pour la sauver des flammes." year="2026-02-19" director="David Victori" actors="Belén Cuesta, Enric Auquer, Candela Martínez, Joaquín Furriel, Diana Gómez, Mika Arias, Magdalena Brotto, Carlos Piera, Alberto Berzal, Bernabé Fernández",FR - Coupe-feu (2026)
