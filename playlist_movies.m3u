#EXTINF:-1 tvg-logo="https://image.tmdb.org/t/p/w600_and_h900_bestv2/lBPpq9f5FNa1fgbcguVh9cOzfg0.jpg" group-title="|PL| PRZYGODOWE/HISTORYCZNE/KOSTIUMOWE" tvg-type="movie" description="In 17th-century France, beautiful country maiden Angélique marries wealthy neighbor Jeoffray de Peyrac out of convenience, but eventually, she falls in love with him. So when Jeoffray is arrested and then vanishes, she bravely sets out to find him. This is the first of many dramas based on Anne and Serge Golon's novels about strong-willed Angélique and her adventures during the reign of Louis XIV, the Sun King." year="1964-12-08" director="Bernard Borderie" actors="Michèle Mercier, Robert Hossein, Jean Rochefort, Claude Giraud, Giuliano Gemma",Angelique (1964)
