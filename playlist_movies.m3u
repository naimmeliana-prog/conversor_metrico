#EXTINF:-1 tvg-logo="https://image.tmdb.org/t/p/w600_and_h900_bestv2/8w1SqGceTYHbVmXh8JHdWHza2SF.jpg" group-title="|DE| FILME KOLLEKTION" tvg-type="movie" description="The Police Academy misfits travel to Miami Beach for Commandant Lassard to be honored with a prestigious lifetime award pending his retirement. Things take a turn when Lassard unknowingly ends up in possession of stolen diamonds from a jewel heist." year="1988-03-17" director="Alan Myerson, Carla Brand Breitner, Cary Gordon, Bill Baker, Marty P. Ewing" actors="Bubba Smith, David Graf, Michael Winslow, Leslie Easterbrook, Marion Ramsey",DE - Police Academy 5: Auftrag Miami Beach (1988)
