#EXTINF:-1 tvg-logo="https://image.tmdb.org/t/p/w600_and_h900_bestv2/cDZRy7uNFZFlTWPgoA9q1TBDdHI.jpg" group-title="|IT| PELLICOLA 2019/2024" tvg-type="movie" description="Il manager di un'azienda produttrice di TV in via di estinzione promette di restituire tutti i soldi derivanti dagli acquisti di TV dei propri clienti se l'Argentina non si qualifica per la Coppa del Mondo FIFA." year="2022-10-20" director="Ariel Winograd" actors="Leonardo Sbaraglia, Carla Peterson, Luis Luque, Cecilia Dopazo, Valentin Wein, Marina Bellati, Mónica Raiola, Agustina Suásquita, Ignacio Saralegui, Martín Piroyansky",IT - The Manager (2022)
