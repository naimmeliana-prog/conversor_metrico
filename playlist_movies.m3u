#EXTINF:-1 tvg-logo="https://image.tmdb.org/t/p/w600_and_h900_bestv2/aQfob5TRbPCIwThSSyUlwXLwoXy.jpg" group-title="|FR| FILMS UHD" tvg-type="movie" description="Entre histoire d'amour et deuil, un bûcheron vit un paisible état de grâce dans le monde en pleine mutation du début du 20e siècle en Amérique." year="2025-11-05" director="Clint Bentley" actors="Joel Edgerton, Felicity Jones, Nathaniel Arcand, Clifton Collins Jr., John Diehl, Paul Schneider, Kerry Condon, William H. Macy, Will Patton, Alfred Hsing",FR - Train Dreams (2025)
