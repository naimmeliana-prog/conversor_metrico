#EXTINF:-1 tvg-logo="https://image.tmdb.org/t/p/w600_and_h900_bestv2/cHwnYGZh1fVuVWqT28GpCN0usYF.jpg" group-title="|FR| COMÉDIE/DRAME" tvg-type="movie" description="Cinq copains de Cardiff, dont la vie revêt le plus souvent des teintes grisâtres, ont pris l'habitude chaque vendredi soir d'aller en boite pour s'amuser. Pour Jip, Koop, Nina, Lulu et Moff, tout peut arriver, même le meilleur, et tous les moyens sont bons." year="1999-06-04" director="Justin Kerrigan" actors="John Simm, Shaun Parkes, Nicola Reynolds, Lorraine Pilkington, Danny Dyer, Dean Davies, Andrew Lincoln, Terence Beesley, Jo Brand, Richard Coyle",FR - Human Traffic (1999)
